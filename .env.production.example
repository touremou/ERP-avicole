# ──────────────────────────────────────────────────────────────
# AviSmart ERP — Modèle de configuration PRODUCTION
# Copier vers .env sur le serveur, puis renseigner les valeurs réelles.
# Ne JAMAIS committer le .env de production.
# ──────────────────────────────────────────────────────────────

APP_NAME="AviSmart"
APP_ENV=production
APP_KEY=                      # php artisan key:generate
APP_DEBUG=false               # CRITIQUE : false en production (sinon fuite de traces)
APP_URL=https://votre-domaine.com
APP_TIMEZONE=Africa/Conakry
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# Journalisation : pas de debug en prod
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# Base de données (MySQL/MariaDB recommandé en prod)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=avismart
DB_USERNAME=avismart
DB_PASSWORD=                  # mot de passe fort, hors du dépôt

# Sessions / cache / file d'attente
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true    # cookies uniquement en HTTPS
SESSION_SAME_SITE=lax
CACHE_STORE=database          # Redis recommandé si disponible
QUEUE_CONNECTION=database

# Stockage des fichiers (logos, photos…)
FILESYSTEM_DISK=public

# Emails (pour les notifications éventuelles)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp (si activé dans Paramètres > WhatsApp)
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_ID=

# Licence / abonnement (monétisation) — OPT-IN.
# Laisser vide pour désactiver toute restriction. Sinon : clé publique générée
# par `php artisan license:keygen` (la clé privée reste chez le fournisseur).
LICENSE_PUBLIC_KEY=
LICENSE_ENFORCE=true
LICENSE_GRACE_DAYS=7
