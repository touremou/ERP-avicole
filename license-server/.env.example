# Serveur de licence fournisseur — variables d'environnement.
# Copier en .env (ou exporter dans l'environnement). NE JAMAIS committer .env.

# Clé privée Ed25519 (base64). Alternative : fichier storage/private.key.
# Générée par : bin/license keygen
LICENSE_PRIVATE_KEY=

# Chemin de la base SQLite du registre (défaut : storage/licenses.sqlite)
LICENSE_DB_PATH=
