    {{-- SCRIPT ALPINE.JS (Moteur de calcul) --}}
    <script>
    function planningForm() {
        const cycles = { chair: 42, ponte: 540, reproducteur: 450 };
        return {
            batchType: 'chair', 
            arrivalDate: '',
            plannedQuantity: '',
            males: '',
            females: '',
            buildingCapacity: 0,
            buildingOccupied: 0,
            buildingRemaining: 0,
            
            // Calcul de la quantité totale en fonction du type
            get totalQuantity() {
                if (this.batchType === 'reproducteur') {
                    return (parseInt(this.males) || 0) + (parseInt(this.females) || 0);
                }
                return parseInt(this.plannedQuantity) || 0;
            },

            // Validation de la capacité du bâtiment
            get capacityError() {
                if (this.buildingCapacity > 0 && this.totalQuantity > this.buildingCapacity) {
                    return `Surcharge Bâtiment ! (Max: ${this.buildingCapacity} pl.)`;
                }
                return null;
            },

            // Mise à jour de la capacité lors du choix du bâtiment
            updateBuilding(e) {
                const selected = e.target.options[e.target.selectedIndex];
                this.buildingCapacity = parseInt(selected.dataset.capacity) || 0;
                this.buildingOccupied = parseInt(selected.dataset.occupied) || 0;
                this.buildingRemaining = parseInt(selected.dataset.remaining) || 0;
            },

            // Calculs de dates
            get cycleDays() { return cycles[this.batchType] || 42; },
            get orderDeadline() { if (!this.arrivalDate) return '—'; return this.addDays(this.arrivalDate, -56); },
            get endDate() { if (!this.arrivalDate) return '—'; return this.addDays(this.arrivalDate, this.cycleDays); },
            get voidEnd() { if (!this.arrivalDate) return '—'; return this.addDays(this.arrivalDate, this.cycleDays + 22); },
            
            addDays(dateStr, days) {
                if (!dateStr) return '—';
                let d = new Date(dateStr); 
                d.setDate(d.getDate() + days);
                return d.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
            },
            formatDate(dateStr) { 
                if (!dateStr) return '—'; 
                return new Date(dateStr).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' }); 
            }
            
        }
    }
    </script>
</x-app-layout>